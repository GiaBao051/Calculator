<Window x:Class="Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Calculator"
        Width="360"
        Height="650"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#202020">

    <!--
        =========================
        KHU VỰC TÀI NGUYÊN GIAO DIỆN
        =========================
        Mục tiêu:
        - Tái sử dụng style để tránh lặp code.
        - Dễ thay đổi giao diện toàn bộ nút chỉ tại 1 nơi.
    -->
    <Window.Resources>
        <!-- Style cơ sở áp dụng chung cho tất cả nút -->
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <!-- Style cho nhóm nút số -->
        <Style x:Key="NumberButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#303030" />
        </Style>

        <!-- Style cho nhóm nút phép toán/chức năng -->
        <Style x:Key="OperatorButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#3B3B3B" />
        </Style>

        <!-- Style nổi bật cho nút '=' -->
        <Style x:Key="EqualButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#005A9E" />
        </Style>
    </Window.Resources>

    <!--
        =========================
        BỐ CỤC CHÍNH CỦA CỬA SỔ
        =========================
        Cấu trúc gồm 7 hàng:
        - Hàng 0: màn hình hiển thị biểu thức và kết quả.
        - Hàng 1..6: các cụm phím chức năng/số.
    -->
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="150" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--
            Khu vực hiển thị:
            - ExpressionTextBlock: dòng biểu thức (ví dụ: 12 + 3 =).
            - ResultTextBlock: dòng kết quả/số đang nhập.
        -->
        <Grid Grid.Row="0" Margin="4 8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="ExpressionTextBlock"
                       Grid.Row="0"
                       Foreground="#B0B0B0"
                       FontSize="20"
                       TextAlignment="Right"
                       TextWrapping="Wrap"
                       Text="" />

            <TextBlock x:Name="ResultTextBlock"
                       Grid.Row="1"
                       Foreground="White"
                       FontSize="48"
                       FontWeight="Bold"
                       TextAlignment="Right"
                       VerticalAlignment="Bottom"
                       Text="0" />
        </Grid>

        <!-- Hàng 1: các thao tác điều khiển nhanh -->
        <!-- % | CE | C | Backspace -->
        <UniformGrid Grid.Row="1" Columns="4">
            <Button Content="%" Tag="Percent" Style="{StaticResource OperatorButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="CE" Tag="CE" Style="{StaticResource OperatorButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="C" Tag="C" Style="{StaticResource OperatorButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="⌫" Tag="Backspace" Style="{StaticResource OperatorButtonStyle}" Click="OnCalculatorButtonClick" />
        </UniformGrid>

        <!-- Hàng 2: các phép toán một ngôi + phép chia -->
        <!-- 1/x | x² | √x | ÷ -->
        <UniformGrid Grid.Row="2" Columns="4">
            <Button Content="1/x" Tag="Reciprocal" Style="{StaticResource OperatorButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="x²" Tag="Square" Style="{StaticResource OperatorButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="√x" Tag="Sqrt" Style="{StaticResource OperatorButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="÷" Tag="/" Style="{StaticResource OperatorButtonStyle}" Click="OnCalculatorButtonClick" />
        </UniformGrid>

        <!-- Hàng 3: 7 8 9 × -->
        <UniformGrid Grid.Row="3" Columns="4">
            <Button Content="7" Tag="7" Style="{StaticResource NumberButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="8" Tag="8" Style="{StaticResource NumberButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="9" Tag="9" Style="{StaticResource NumberButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="×" Tag="*" Style="{StaticResource OperatorButtonStyle}" Click="OnCalculatorButtonClick" />
        </UniformGrid>

        <!-- Hàng 4: 4 5 6 − -->
        <UniformGrid Grid.Row="4" Columns="4">
            <Button Content="4" Tag="4" Style="{StaticResource NumberButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="5" Tag="5" Style="{StaticResource NumberButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="6" Tag="6" Style="{StaticResource NumberButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="−" Tag="-" Style="{StaticResource OperatorButtonStyle}" Click="OnCalculatorButtonClick" />
        </UniformGrid>

        <!-- Hàng 5: 1 2 3 + -->
        <UniformGrid Grid.Row="5" Columns="4">
            <Button Content="1" Tag="1" Style="{StaticResource NumberButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="2" Tag="2" Style="{StaticResource NumberButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="3" Tag="3" Style="{StaticResource NumberButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="+" Tag="+" Style="{StaticResource OperatorButtonStyle}" Click="OnCalculatorButtonClick" />
        </UniformGrid>

        <!-- Hàng 6: đổi dấu | 0 | dấu chấm | bằng -->
        <UniformGrid Grid.Row="6" Columns="4">
            <Button Content="+/−" Tag="ToggleSign" Style="{StaticResource NumberButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="0" Tag="0" Style="{StaticResource NumberButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="." Tag="." Style="{StaticResource NumberButtonStyle}" Click="OnCalculatorButtonClick" />
            <Button Content="=" Tag="=" Style="{StaticResource EqualButtonStyle}" Click="OnCalculatorButtonClick" />
        </UniformGrid>
    </Grid>
</Window>
