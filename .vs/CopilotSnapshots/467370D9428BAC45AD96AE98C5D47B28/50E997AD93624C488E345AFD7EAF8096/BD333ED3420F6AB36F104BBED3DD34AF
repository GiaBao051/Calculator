using System;
using System.Windows.Input;

namespace Calculator.Commands;

// RelayCommand bọc một Action thành ICommand.
// Dùng khi nút bấm KHÔNG cần truyền tham số vào hàm xử lý.
//
// Ví dụ:
//   EqualCommand = new RelayCommand(OnEqualPressed);
public class RelayCommand : ICommand
{
    private readonly Action _execute;
    private readonly Func<bool>? _canExecute;

    public RelayCommand(Action execute, Func<bool>? canExecute = null)
    {
        _execute = execute;
        _canExecute = canExecute;
    }

    // WPF gọi hàm này để quyết định có disable nút không.
    public bool CanExecute(object? parameter) => _canExecute?.Invoke() ?? true;

    // WPF gọi hàm này khi người dùng bấm nút.
    public void Execute(object? parameter) => _execute();

    // Sự kiện để báo WPF kiểm tra lại CanExecute.
    public event EventHandler? CanExecuteChanged
    {
        add => CommandManager.RequerySuggested += value;
        remove => CommandManager.RequerySuggested -= value;
    }
}

// RelayCommand<T> bọc một Action<T> thành ICommand.
// Dùng khi nút bấm CẦN truyền tham số qua CommandParameter trong XAML.
//
// Ví dụ:
//   NumberCommand = new RelayCommand<string>(OnNumberPressed);
//   XAML: CommandParameter="7"
public class RelayCommand<T> : ICommand
{
    private readonly Action<T> _execute;
    private readonly Func<T, bool>? _canExecute;

    public RelayCommand(Action<T> execute, Func<T, bool>? canExecute = null)
    {
        _execute = execute;
        _canExecute = canExecute;
    }

    public bool CanExecute(object? parameter)
    {
        if (parameter is T value)
            return _canExecute?.Invoke(value) ?? true;

        return true;
    }

    public void Execute(object? parameter)
    {
        if (parameter is T value)
            _execute(value);
    }

    public event EventHandler? CanExecuteChanged
    {
        add => CommandManager.RequerySuggested += value;
        remove => CommandManager.RequerySuggested -= value;
    }
}
