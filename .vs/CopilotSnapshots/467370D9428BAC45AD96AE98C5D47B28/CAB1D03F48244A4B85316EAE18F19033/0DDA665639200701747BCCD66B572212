<Window x:Class="Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Calculator.ViewModels"
        mc:Ignorable="d"
        Title="Calculator"
        Width="760"
        Height="680"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        Background="#202020">

    <d:Window.DataContext>
        <vm:CalculatorViewModel />
    </d:Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="D0" Command="{Binding NumberCommand}" CommandParameter="0" />
        <KeyBinding Key="D1" Command="{Binding NumberCommand}" CommandParameter="1" />
        <KeyBinding Key="D2" Command="{Binding NumberCommand}" CommandParameter="2" />
        <KeyBinding Key="D3" Command="{Binding NumberCommand}" CommandParameter="3" />
        <KeyBinding Key="D4" Command="{Binding NumberCommand}" CommandParameter="4" />
        <KeyBinding Key="D5" Command="{Binding NumberCommand}" CommandParameter="5" />
        <KeyBinding Key="D6" Command="{Binding NumberCommand}" CommandParameter="6" />
        <KeyBinding Key="D7" Command="{Binding NumberCommand}" CommandParameter="7" />
        <KeyBinding Key="D8" Command="{Binding NumberCommand}" CommandParameter="8" />
        <KeyBinding Key="D9" Command="{Binding NumberCommand}" CommandParameter="9" />

        <KeyBinding Key="NumPad0" Command="{Binding NumberCommand}" CommandParameter="0" />
        <KeyBinding Key="NumPad1" Command="{Binding NumberCommand}" CommandParameter="1" />
        <KeyBinding Key="NumPad2" Command="{Binding NumberCommand}" CommandParameter="2" />
        <KeyBinding Key="NumPad3" Command="{Binding NumberCommand}" CommandParameter="3" />
        <KeyBinding Key="NumPad4" Command="{Binding NumberCommand}" CommandParameter="4" />
        <KeyBinding Key="NumPad5" Command="{Binding NumberCommand}" CommandParameter="5" />
        <KeyBinding Key="NumPad6" Command="{Binding NumberCommand}" CommandParameter="6" />
        <KeyBinding Key="NumPad7" Command="{Binding NumberCommand}" CommandParameter="7" />
        <KeyBinding Key="NumPad8" Command="{Binding NumberCommand}" CommandParameter="8" />
        <KeyBinding Key="NumPad9" Command="{Binding NumberCommand}" CommandParameter="9" />

        <KeyBinding Key="Decimal" Command="{Binding DecimalCommand}" />
        <KeyBinding Key="OemPeriod" Command="{Binding DecimalCommand}" />

        <KeyBinding Key="Add" Command="{Binding OperatorCommand}" CommandParameter="+" />
        <KeyBinding Key="Subtract" Command="{Binding OperatorCommand}" CommandParameter="-" />
        <KeyBinding Key="Multiply" Command="{Binding OperatorCommand}" CommandParameter="*" />
        <KeyBinding Key="Divide" Command="{Binding OperatorCommand}" CommandParameter="/" />

        <KeyBinding Key="Enter" Command="{Binding EqualCommand}" />
        <KeyBinding Key="Return" Command="{Binding EqualCommand}" />
        <KeyBinding Key="Back" Command="{Binding BackspaceCommand}" />
        <KeyBinding Key="Escape" Command="{Binding ResetCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <Style x:Key="BaseButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="4" />
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NumberButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#303030" />
        </Style>

        <Style x:Key="OperatorButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#3B3B3B" />
        </Style>

        <Style x:Key="EqualButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButtonStyle}">
            <Setter Property="Background" Value="#005A9E" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="260" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0 0 12 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="150" />
                <RowDefinition Height="54" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="4 8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Foreground="#B0B0B0"
                           FontSize="18"
                           TextAlignment="Right"
                           TextWrapping="Wrap"
                           Text="{Binding ExpressionText}" />

                <TextBlock Grid.Row="1"
                           Foreground="White"
                           FontSize="46"
                           FontWeight="Bold"
                           TextAlignment="Right"
                           VerticalAlignment="Bottom"
                           Text="{Binding DisplayText}" />
            </Grid>

            <UniformGrid Grid.Row="1" Columns="5">
                <Button Content="MC" Style="{StaticResource OperatorButtonStyle}" Command="{Binding MemoryClearCommand}" IsEnabled="{Binding HasMemory}" />
                <Button Content="MR" Style="{StaticResource OperatorButtonStyle}" Command="{Binding MemoryRecallCommand}" IsEnabled="{Binding HasMemory}" />
                <Button Content="MS" Style="{StaticResource OperatorButtonStyle}" Command="{Binding MemoryStoreCommand}" />
                <Button Content="M+" Style="{StaticResource OperatorButtonStyle}" Command="{Binding MemoryAddCommand}" />
                <Button Content="M-" Style="{StaticResource OperatorButtonStyle}" Command="{Binding MemorySubtractCommand}" />
            </UniformGrid>

            <UniformGrid Grid.Row="2" Columns="4">
                <Button Content="%" Style="{StaticResource OperatorButtonStyle}" Command="{Binding PercentCommand}" />
                <Button Content="CE" Style="{StaticResource OperatorButtonStyle}" Command="{Binding ClearEntryCommand}" />
                <Button Content="C" Style="{StaticResource OperatorButtonStyle}" Command="{Binding ResetCommand}" />
                <Button Content="⌫" Style="{StaticResource OperatorButtonStyle}" Command="{Binding BackspaceCommand}" />
            </UniformGrid>

            <UniformGrid Grid.Row="3" Columns="4">
                <Button Content="1/x" Style="{StaticResource OperatorButtonStyle}" Command="{Binding UnaryCommand}" CommandParameter="Reciprocal" />
                <Button Content="x²" Style="{StaticResource OperatorButtonStyle}" Command="{Binding UnaryCommand}" CommandParameter="Square" />
                <Button Content="√x" Style="{StaticResource OperatorButtonStyle}" Command="{Binding UnaryCommand}" CommandParameter="Sqrt" />
                <Button Content="÷" Style="{StaticResource OperatorButtonStyle}" Command="{Binding OperatorCommand}" CommandParameter="/" />
            </UniformGrid>

            <UniformGrid Grid.Row="4" Columns="4">
                <Button Content="7" Style="{StaticResource NumberButtonStyle}" Command="{Binding NumberCommand}" CommandParameter="7" />
                <Button Content="8" Style="{StaticResource NumberButtonStyle}" Command="{Binding NumberCommand}" CommandParameter="8" />
                <Button Content="9" Style="{StaticResource NumberButtonStyle}" Command="{Binding NumberCommand}" CommandParameter="9" />
                <Button Content="×" Style="{StaticResource OperatorButtonStyle}" Command="{Binding OperatorCommand}" CommandParameter="*" />
            </UniformGrid>

            <UniformGrid Grid.Row="5" Columns="4">
                <Button Content="4" Style="{StaticResource NumberButtonStyle}" Command="{Binding NumberCommand}" CommandParameter="4" />
                <Button Content="5" Style="{StaticResource NumberButtonStyle}" Command="{Binding NumberCommand}" CommandParameter="5" />
                <Button Content="6" Style="{StaticResource NumberButtonStyle}" Command="{Binding NumberCommand}" CommandParameter="6" />
                <Button Content="−" Style="{StaticResource OperatorButtonStyle}" Command="{Binding OperatorCommand}" CommandParameter="-" />
            </UniformGrid>

            <UniformGrid Grid.Row="6" Columns="4">
                <Button Content="1" Style="{StaticResource NumberButtonStyle}" Command="{Binding NumberCommand}" CommandParameter="1" />
                <Button Content="2" Style="{StaticResource NumberButtonStyle}" Command="{Binding NumberCommand}" CommandParameter="2" />
                <Button Content="3" Style="{StaticResource NumberButtonStyle}" Command="{Binding NumberCommand}" CommandParameter="3" />
                <Button Content="+" Style="{StaticResource OperatorButtonStyle}" Command="{Binding OperatorCommand}" CommandParameter="+" />
            </UniformGrid>

            <UniformGrid Grid.Row="7" Columns="4">
                <Button Content="+/−" Style="{StaticResource NumberButtonStyle}" Command="{Binding ToggleSignCommand}" />
                <Button Content="0" Style="{StaticResource NumberButtonStyle}" Command="{Binding NumberCommand}" CommandParameter="0" />
                <Button Content="." Style="{StaticResource NumberButtonStyle}" Command="{Binding DecimalCommand}" />
                <Button Content="=" Style="{StaticResource EqualButtonStyle}" Command="{Binding EqualCommand}" />
            </UniformGrid>
        </Grid>

        <Border Grid.Column="1" Background="#252525" CornerRadius="8" Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="History"
                           Foreground="White"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0 0 0 8" />

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding HistoryItems}"
                         Background="#252525"
                         Foreground="#E6E6E6"
                         BorderThickness="0"
                         FontSize="14" />

                <Button Grid.Row="2"
                        Content="Clear History"
                        Style="{StaticResource OperatorButtonStyle}"
                        FontSize="14"
                        Margin="0 8 0 0"
                        Command="{Binding ClearHistoryCommand}" />
            </Grid>
        </Border>
    </Grid>
</Window>
